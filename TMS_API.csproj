    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>d5156d1f-9427-41c0-8280-ce2af9602b8a</UserSecretsId>
    <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
